# Font
font=Noto Sans 10

# Appearance
background-color=#000000ee
text-color=#bbbbbbff
border-color=#333333ff
border-size=2
border-radius=10
padding=16
margin=20

# Notification lifespan
default-timeout=5000

# Layout
max-visible=5
anchor=top-right
width=400

# Layer
layer=overlay

# Icons (optional if you use them)
icons=1
icon-path=/usr/share/icons

# Hide on mouse hover (nice UX)

# Critical urgency style
[urgency=critical]
border-color=#8b1a1aff
background-color=#000000ff
text-color=#bbbbbbff
default-timeout=0

# Low urgency style (optional)
[urgency=low]
background-color=#000000aa
text-color=#666666ff
border-color=#1a1a1aff
